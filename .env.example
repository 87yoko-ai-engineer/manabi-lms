# ============================================================
# 環境変数の見本 — このファイルを .env にコピーして値を埋める
#   cp .env.example .env
# .env は .gitignore 済み(コミットされない)
# ============================================================

# Neon PostgreSQL の接続文字列
# https://console.neon.tech → プロジェクト → Connection string からコピー
# 開発時は development ブランチ、本番(Vercel側で設定)は main ブランチを使う
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Auth.js のセッション署名キー(十分長いランダム文字列)
# 生成例: npx auth secret  または  openssl rand -base64 32
AUTH_SECRET="your-random-secret-here"
